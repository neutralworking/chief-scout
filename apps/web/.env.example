# Supabase credentials for the Next.js app
# Copy this to .env.local and fill in real values

NEXT_PUBLIC_SUPABASE_URL=https://fnvlemkbhohyouhjebwf.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only — used by server components (never exposed to browser)
SUPABASE_URL=https://fnvlemkbhohyouhjebwf.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here

# Environment: "staging" (default) or "production"
# Set to "production" on the prod Vercel project
NEXT_PUBLIC_APP_ENV=staging

# Stripe — subscription billing (required for /pricing + checkout)
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Stripe Price IDs — create products in Stripe Dashboard first
# Scout tier: £7/mo monthly, £59/yr annual
NEXT_PUBLIC_STRIPE_SCOUT_PRICE_ID=price_scout_monthly_id
NEXT_PUBLIC_STRIPE_SCOUT_ANNUAL_PRICE_ID=price_scout_annual_id
STRIPE_SCOUT_PRICE_ID=price_scout_monthly_id

# Pro tier: £19/mo monthly, £149/yr annual
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_pro_monthly_id
NEXT_PUBLIC_STRIPE_PRO_ANNUAL_PRICE_ID=price_pro_annual_id
STRIPE_PRO_PRICE_ID=price_pro_monthly_id

# App URL — used for Stripe checkout success/cancel redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000
